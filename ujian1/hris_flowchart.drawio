<mxfile host="app.diagrams.net">
  <diagram id="hris-flow" name="HRIS Flowchart">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="START APPLICATION" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Main Menu -->
        <mxCell id="menu" value="MAIN MENU&#xa;1. Register FullTime&#xa;2. Register Contract&#xa;3. Register Freelancer&#xa;4. Show Payroll Report&#xa;5. Show Total Payout&#xa;6. Seed Dummy Data&#xa;0. Exit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="420" height="180" as="geometry"/>
        </mxCell>

        <!-- Register FullTime -->
        <mxCell id="fulltime" value="Register FullTime Employee&#xa;- Input ID&#xa;- Input Name&#xa;- Input Salary&#xa;- Validation&#xa;- Save to HRIS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="220" height="170" as="geometry"/>
        </mxCell>

        <!-- Register Contract -->
        <mxCell id="contract" value="Register Contract Employee&#xa;- Input ID&#xa;- Input Name&#xa;- Input Monthly Rate&#xa;- Input Bonus&#xa;- Validation&#xa;- Save to HRIS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="400" width="220" height="190" as="geometry"/>
        </mxCell>

        <!-- Register Freelancer -->
        <mxCell id="freelancer" value="Register Freelancer&#xa;- Input ID&#xa;- Input Name&#xa;- Input Hourly Rate&#xa;- Input Hours Worked&#xa;- Validation&#xa;- Save to HRIS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="220" height="190" as="geometry"/>
        </mxCell>

        <!-- Report -->
        <mxCell id="report" value="Show Payroll Report&#xa;- Iterate Payrolls Map&#xa;- Type Switch&#xa;- Print Employee Details&#xa;- Calculate Salary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="820" y="400" width="240" height="170" as="geometry"/>
        </mxCell>

        <!-- Total -->
        <mxCell id="total" value="Calculate Total Payout&#xa;- Iterate Payrolls&#xa;- Sum Salary&#xa;- Print Total Budget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="1120" y="400" width="220" height="150" as="geometry"/>
        </mxCell>

        <!-- Exit -->
        <mxCell id="exit" value="EXIT APPLICATION" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="420" y="700" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="start" target="menu">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" value="1" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="fulltime">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="2" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="contract">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="3" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="freelancer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="4" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="report">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="5" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="total">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="0" style="endArrow=block;html=1;" edge="1" parent="1" source="menu" target="exit">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
